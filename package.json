{
  "name": "arsnova-lite",
  "version": "1.3.0-SNAPSHOT",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --configuration production",
    "test": "ng test --watch=false --browsers=ChromeHeadlessCustom --source-map=false --code-coverage",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "extract": "ngx-translate-extract -m _ --input ./src --output ./src/assets/i18n/de.json ./src/assets/i18n/en.json --clean --sort --format namespaced-json",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "i18n:sort": "node ./src/assets/i18n/i18nUpdater.js sort",
    "i18n:add-language": "node ./src/assets/i18n/i18nUpdater.js add-language",
    "i18n:find-missing": "node ./src/assets/i18n/i18nUpdater.js missing",
    "i18n:count-untranslated": "node ./src/assets/i18n/i18nUpdater.js untranslated",
    "i18n:find-untranslated": "node ./src/assets/i18n/i18nUpdater.js untranslated --show-all",
    "i18n:find-unused": "node ./src/assets/i18n/i18nUpdater.js project-unused"
  },
  "private": true,
  "dependencies": {
    "@angular-devkit/architect": "^0.1501.3",
    "@angular-material-components/datetime-picker": "^9.0.0",
    "@angular/animations": "^15.1.2",
