    "ngx-indexed-db": "^12.0.0",
    "ngx-joyride": "^2.4.0",
    "ngx-markdown": "^15.1.0",
    "ngx-matomo-v9": "^0.8.0",
    "ngx-quill": "^20.0.1",
    "prismjs": "^1.29.0",
    "quill": "^1.3.7",
    "quill-emoji": "^0.2.0",
